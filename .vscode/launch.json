{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "debugpy",
            "request": "launch",
            "name": "marimo debug: edit mode",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "MARIMO_SCRIPT_EDIT": "1"
            },
            "justMyCode": false
        }
    ]
}